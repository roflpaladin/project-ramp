# Supabase project (placeholders — replace with real values from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used to read/write workspaces & links for buyer /portal routes,
# where the visitor is authenticated via a magic-link token, not Supabase Auth,
# and therefore can't satisfy the tenant_id RLS policies. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signs the buyer's portal-access cookie after a magic-link code is verified.
# Any long random string; generate with e.g. `openssl rand -hex 32`.
PORTAL_SESSION_SECRET=replace-with-a-long-random-string

# SMTP relay used to send the buyer's 4-digit access code (Sprint 2, Ticket 10).
# Use your Supabase project's Auth -> SMTP settings, or any SMTP provider.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Project Ramp <noreply@yourdomain.com>"
